const adSchema = new mongoose.Schema({
  name: {
    type: String,
    required: true,
    trim: true
  },
  placement: {
    type: String,
    required: true,
    enum: [
      'home_top', 'home_sidebar', 'home_infeed', 'home_footer',
      'watch_sidebar', 'watch_below', 'watch_related', 'watch_overlay',
      'search_top', 'category_top', 'popunder', 'interstitial'
